datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Equipment {
  id       String @id @default(uuid())
  name     String
  type     String // "IceCreamMaker", "CoffeeMachine"
  programs Json   // es. ["Gelato", "Sorbetto", "MIX"]
}

model Ingredient {
  id         String  @id @default(uuid())
  name       String
  quantity   Float
  unit       String
  isCritical Boolean @default(false)
}

model Recipe {
  id                String          @id @default(uuid())
  title             String
  category          String          // "Gelato", "Sorbetto", "Granita", "NiceCream"
  description       String
  ingredients       Json            // Array di { name: string, quantity: number, unit: string }
  steps             Json            // Array di { stepNumber: number, instruction: string, tempMin?: number, tempMax?: number }
  programUsed       String          // Programma consigliato (es. "Yogurt Gelato")
  hasMixIn          Boolean         @default(false)
  mixInInstructions String?
  freezeTrackers    FreezeTracker[]
}

model FreezeTracker {
  id        String   @id @default(uuid())
  pintaName String
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id])
  createdAt DateTime @default(now())
  readyAt   DateTime // Impostata a createdAt + 24 ore
  isSpun    Boolean  @default(false)
}
